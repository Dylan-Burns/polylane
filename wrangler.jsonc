{
  "name": "watchtower",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-01",
  // No `build.command` here: the UI is built by the root `build:ui` script
  // (`vite build` in ui/ -> ui/dist). The canonical deploy path is
  // `pnpm deploy`, which runs `build:ui && wrangler deploy`. Running bare
  // `wrangler deploy`/`wrangler dev` will serve whatever is already in
  // ui/dist (or 404 on assets if it hasn't been built yet).
  "assets": {
    "directory": "ui/dist",
    "not_found_handling": "single-page-application",
    // "/__scheduled" exists so `wrangler dev --test-scheduled` can actually reach the scheduled
    // handler: without it the SPA fallback swallows the request and the cron sweep can never be
    // fired locally. In production the path simply 404s from the worker instead of serving the
    // app shell — nothing routes there.
    "run_worker_first": ["/api/*", "/__scheduled"]
  },
  "d1_databases": [{ "binding": "DB", "database_name": "watchtower", "database_id": "39cc28fd-a81f-40df-a34d-d4eed5b53746", "migrations_dir": "migrations" }],
  "durable_objects": { "bindings": [
    { "name": "SIMULATOR", "class_name": "SimulatorDO" },
    { "name": "INVESTIGATOR", "class_name": "InvestigatorDO" }
  ]},
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["SimulatorDO", "InvestigatorDO"] }],
  "triggers": { "crons": ["* * * * *"] },
  "vars": { "MODEL_ID": "claude-sonnet-5", "SIM_RATE": "1.0" }
}
